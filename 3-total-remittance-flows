<script>
(() => {
  const data = JSON.parse(document.getElementById('vizData').textContent);
  const countries = data.countries;
  const regionOrder = data.regionOrder;
  const regionColours = data.regionColours;
  const state = { income:'All income groups', country:'ALL', activeRegion:null };
  const svg = document.getElementById('scatterSvg');
  const tooltip = document.getElementById('tooltip');
  const incomeSelect = document.getElementById('incomeSelect');
  const countrySelect = document.getElementById('countrySelect');
  const countryInput = document.getElementById('countryInput');
  const countryMenu = document.getElementById('countryMenu');
  const scatterTitle = document.getElementById('scatterTitle');

  const esc = v => String(v ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  const fmtMoney = v => {
    if (v === null || v === undefined || !isFinite(v)) return 'N/A';
    const av = Math.abs(v);
    if (av >= 1e12) return '$' + (v/1e12).toFixed(av >= 10e12 ? 0 : 1).replace(/\.0$/,'') + 'tn';
    if (av >= 1e9) return '$' + (v/1e9).toFixed(av >= 10e9 ? 0 : 1).replace(/\.0$/,'') + 'bn';
    if (av >= 1e6) return '$' + (v/1e6).toFixed(av >= 10e6 ? 0 : 1).replace(/\.0$/,'') + 'm';
    if (av >= 1e3) return '$' + (v/1e3).toFixed(av >= 10e3 ? 0 : 1).replace(/\.0$/,'') + 'k';
    return '$' + Math.round(v).toLocaleString();
  };
  const fmtMoneyFull = v => '$' + Math.round(v).toLocaleString('en-US');
  const fmtPct = v => {
    if (v === null || v === undefined || !isFinite(v)) return 'N/A';
    const sign = v > 0 ? '+' : '';
    const av = Math.abs(v*100);
    const dec = av >= 10 ? 0 : 1;
    return sign + (v*100).toFixed(dec) + '%';
  };
  const fmtChange = v => (v > 0 ? '+' : v < 0 ? '−' : '') + fmtMoneyFull(Math.abs(v));

  function filteredBase() {
    return countries.filter(d => state.income === 'All income groups' || d.income === state.income);
  }
  function filteredForSummary() {
    const rows = filteredBase().filter(d => !state.activeRegion || d.region === state.activeRegion);
    return rows;
  }

  function initControls() {
    const incomes = ['All income groups', ...data.summary.incomes];
    incomeSelect.innerHTML = incomes.map(v => `<option value="${esc(v)}">${esc(v)}</option>`).join('');
    incomeSelect.value = state.income;
    incomeSelect.addEventListener('change', () => {
      state.income = incomeSelect.value;
      const rows = filteredBase();
      if (state.country !== 'ALL' && !rows.some(d => d.id === state.country)) state.country = 'ALL';
      if (state.activeRegion && !rows.some(d => d.region === state.activeRegion)) state.activeRegion = null;
      updateCountryInput();
      render();
    });

    countryInput.addEventListener('focus', () => openCountryMenu(''));
    countryInput.addEventListener('click', () => openCountryMenu(''));
    countryInput.addEventListener('input', () => openCountryMenu(countryInput.value));
    countryInput.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeCountryMenu();
      if (e.key === 'Enter') {
        const first = countryMenu.querySelector('.select-option');
        if (first) { e.preventDefault(); first.click(); }
      }
    });
    document.addEventListener('click', e => { if (!countrySelect.contains(e.target)) closeCountryMenu(); });
  }

  function updateCountryInput() {
    const found = countries.find(d => d.id === state.country);
    countryInput.value = found ? found.name : '';
    countryInput.placeholder = 'All countries';
  }
  function openCountryMenu(query) {
    const q = (query || '').trim().toLowerCase();
    const rows = filteredBase().slice().sort((a,b) => a.name.localeCompare(b.name));
    const matched = rows.filter(d => !q || d.name.toLowerCase().includes(q) || d.id.toLowerCase().includes(q));
    const options = [`<button type="button" class="select-option ${state.country==='ALL'?'active':''}" data-id="ALL" role="option">All countries</button>`]
      .concat(matched.map(d => `<button type="button" class="select-option ${state.country===d.id?'active':''}" data-id="${esc(d.id)}" role="option">${esc(d.name)}</button>`));
    countryMenu.innerHTML = options.length ? options.join('') : '<div class="select-empty">No matching country</div>';
    countryMenu.querySelectorAll('.select-option').forEach(btn => {
      btn.addEventListener('mousedown', e => e.preventDefault());
      btn.addEventListener('click', () => {
        state.country = btn.dataset.id;
        updateCountryInput();
        closeCountryMenu();
        render();
      });
    });
    countrySelect.classList.add('open');
    countryInput.setAttribute('aria-expanded','true');
  }
  function closeCountryMenu() {
    countrySelect.classList.remove('open');
    countryInput.setAttribute('aria-expanded','false');
    updateCountryInput();
  }

  function renderLegend() {
    const legend = document.getElementById('regionLegend');
    const rows = filteredBase();
    const present = new Set(rows.map(d => d.region));
    legend.innerHTML = regionOrder.filter(r => present.has(r)).map(region => {
      const active = state.activeRegion === region;
      const muted = state.activeRegion && !active;
      return `<button type="button" class="legend-item${active?' active':''}${muted?' muted':''}" data-region="${esc(region)}"><span class="swatch" style="--swatch:${regionColours[region] || regionColours.Other}"></span>${esc(region)}</button>`;
    }).join('');
    legend.querySelectorAll('.legend-item').forEach(btn => {
      btn.addEventListener('click', () => {
        const region = btn.dataset.region;
        state.activeRegion = state.activeRegion === region ? null : region;
        render();
      });
    });
  }

  function niceLogDomain(rows) {
    const vals = [];
    rows.forEach(d => { vals.push(d.v2021, d.v2024); });
    const min = Math.min(...vals.filter(v => v > 0));
    const max = Math.max(...vals.filter(v => v > 0));
    function lowerNice(x) {
      const p = Math.pow(10, Math.floor(Math.log10(x)));
      const m = x / p;
      if (m < 2) return p;
      if (m < 5) return 2*p;
      return 5*p;
    }
    function upperNice(x) {
      const p = Math.pow(10, Math.floor(Math.log10(x)));
      const m = x / p;
      if (m <= 1) return p;
      if (m <= 2) return 2*p;
      if (m <= 5) return 5*p;
      return 10*p;
    }
    return [lowerNice(min), upperNice(max)];
  }
  function logScale(domain, range) {
    const d0 = Math.log10(domain[0]), d1 = Math.log10(domain[1]);
    const r0 = range[0], r1 = range[1];
    return v => r0 + ((Math.log10(v) - d0) / (d1 - d0)) * (r1 - r0);
  }
  function ticksFor(domain) {
    const out = [];
    const start = Math.floor(Math.log10(domain[0]));
    const end = Math.ceil(Math.log10(domain[1]));
    for (let p = start; p <= end; p++) {
      const v = Math.pow(10,p);
      if (v >= domain[0]*0.999 && v <= domain[1]*1.001) out.push(v);
    }
    if (out.length < 4) {
      [1,2,5].forEach(m => {
        for (let p = start; p <= end; p++) {
          const v = m*Math.pow(10,p);
          if (v >= domain[0]*0.999 && v <= domain[1]*1.001 && !out.includes(v)) out.push(v);
        }
      });
      out.sort((a,b) => a-b);
    }
    return out.slice(0,8);
  }

  function updateSummary() {
    const label = state.income === 'All income groups' ? 'Total remittances received, 2021 vs 2024' : `${state.income} countries: total remittances received, 2021 vs 2024`;
    scatterTitle.textContent = state.activeRegion ? `${label} — ${state.activeRegion} highlighted` : label;
  }

  function renderScatter() {
    const rows = filteredBase();
    const box = svg.getBoundingClientRect();
    const width = Math.max(320, box.width || 900);
    const height = Math.max(320, box.height || 430);
    const margin = width < 520 ? {top:18,right:12,bottom:54,left:54} : {top:18,right:20,bottom:58,left:72};
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;
    const domain = niceLogDomain(rows);
    const x = logScale(domain, [margin.left, margin.left + innerW]);
    const y = logScale(domain, [margin.top + innerH, margin.top]);
    const ticks = ticksFor(domain);
    const pointRows = rows.slice().sort((a,b) => b.v2024 - a.v2024);
    const selected = rows.find(d => d.id === state.country);
    const out = [];
    out.push(`<rect x="0" y="0" width="${width}" height="${height}" fill="#fff"></rect>`);
    ticks.forEach(t => {
      out.push(`<line class="grid-line" x1="${x(t).toFixed(2)}" x2="${x(t).toFixed(2)}" y1="${margin.top}" y2="${margin.top+innerH}"></line>`);
      out.push(`<line class="grid-line" x1="${margin.left}" x2="${margin.left+innerW}" y1="${y(t).toFixed(2)}" y2="${y(t).toFixed(2)}"></line>`);
    });
    out.push(`<line class="diag-line" x1="${x(domain[0]).toFixed(2)}" y1="${y(domain[0]).toFixed(2)}" x2="${x(domain[1]).toFixed(2)}" y2="${y(domain[1]).toFixed(2)}"></line>`);
    out.push(`<g class="axis">`);
    out.push(`<line x1="${margin.left}" y1="${margin.top+innerH}" x2="${margin.left+innerW}" y2="${margin.top+innerH}"></line>`);
    out.push(`<line x1="${margin.left}" y1="${margin.top}" x2="${margin.left}" y2="${margin.top+innerH}"></line>`);
    ticks.forEach(t => {
      out.push(`<line x1="${x(t).toFixed(2)}" y1="${margin.top+innerH}" x2="${x(t).toFixed(2)}" y2="${margin.top+innerH+4}"></line>`);
      out.push(`<text x="${x(t).toFixed(2)}" y="${margin.top+innerH+18}" text-anchor="middle">${fmtMoney(t)}</text>`);
      out.push(`<line x1="${margin.left-4}" y1="${y(t).toFixed(2)}" x2="${margin.left}" y2="${y(t).toFixed(2)}"></line>`);
      out.push(`<text x="${margin.left-8}" y="${(y(t)+3).toFixed(2)}" text-anchor="end">${fmtMoney(t)}</text>`);
    });
    out.push(`</g>`);
    out.push(`<text class="axis-title" x="${margin.left+innerW/2}" y="${height-16}" text-anchor="middle">Total remittances received in 2021 (current US$)</text>`);
    out.push(`<text class="axis-title" transform="translate(16 ${margin.top+innerH/2}) rotate(-90)" text-anchor="middle">Total remittances received in 2024 (current US$)</text>`);
    pointRows.forEach(d => {
      if (state.country !== 'ALL' && d.id === state.country) return;
      const regionMuted = state.activeRegion && d.region !== state.activeRegion;
      const focusMuted = state.country !== 'ALL';
      const cls = `point${regionMuted?' muted':''}${focusMuted?' context-muted':''}`;
      out.push(`<circle class="${cls}" data-id="${esc(d.id)}" cx="${x(d.v2021).toFixed(2)}" cy="${y(d.v2024).toFixed(2)}" r="4.2" fill="${regionColours[d.region] || regionColours.Other}" tabindex="0" role="button" aria-label="${esc(d.name)}"></circle>`);
    });
    if (selected) {
      out.push(`<circle class="point selected" data-id="${esc(selected.id)}" cx="${x(selected.v2021).toFixed(2)}" cy="${y(selected.v2024).toFixed(2)}" r="5.4" fill="${regionColours[selected.region] || regionColours.Other}" tabindex="0" role="button" aria-label="${esc(selected.name)}"></circle>`);
    }
    out.push(`<text class="quadrant-label" x="${margin.left+innerW*.78}" y="${margin.top+innerH*.14}" text-anchor="middle">Higher in 2024</text>`);
    out.push(`<text class="quadrant-label" x="${margin.left+innerW*.28}" y="${margin.top+innerH*.83}" text-anchor="middle">Lower in 2024</text>`);
    svg.innerHTML = out.join('');
    svg.querySelectorAll('.point').forEach(el => {
      const d = countries.find(c => c.id === el.dataset.id);
      el.addEventListener('mouseenter', e => showTip(d,e));
      el.addEventListener('mousemove', moveTooltip);
      el.addEventListener('mouseleave', hideTooltip);
      el.addEventListener('click', e => {
        e.stopPropagation();
        state.country = d.id;
        updateCountryInput();
        render();
        showTip(d,e);
      });
      el.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); state.country = d.id; updateCountryInput(); render(); } });
    });
  }

  function showTip(d,e) {
    if (!d) return;
    showTooltip(`<strong>${esc(d.name)}</strong><div class="tooltip-grid"><span>Region</span><b>${esc(d.region)}</b><span>Income group</span><b>${esc(d.income)}</b><span>2021 inflows</span><b>${fmtMoneyFull(d.v2021)}</b><span>2024 inflows</span><b>${fmtMoneyFull(d.v2024)}</b><span>Change</span><b>${fmtChange(d.change)} (${fmtPct(d.pctChange)})</b></div>`, e);
  }
  function showTooltip(html,e) { tooltip.innerHTML = html; tooltip.hidden=false; tooltip.style.opacity=1; moveTooltip(e); }
  function moveTooltip(e) {
    const pad=14;
    let x=e.clientX, y=e.clientY-12;
    tooltip.style.left=x+'px'; tooltip.style.top=y+'px';
    const r=tooltip.getBoundingClientRect();
    if (r.left < pad) x += pad - r.left;
    if (r.right > window.innerWidth - pad) x -= r.right - (window.innerWidth - pad);
    if (r.top < pad) y = e.clientY + 20;
    tooltip.style.left=x+'px'; tooltip.style.top=y+'px';
  }
  function hideTooltip() { tooltip.style.opacity=0; tooltip.hidden=true; }

  function render() {
    renderLegend();
    updateSummary();
    renderScatter();
  }

  const wrapper = document.querySelector('.viz-wrapper');
  const fullscreenBtn = document.getElementById('fullscreenBtn');
  function syncFullscreenButton() {
    const isFullscreen = document.fullscreenElement === wrapper;
    fullscreenBtn.setAttribute('aria-label', isFullscreen ? 'Exit fullscreen' : 'View fullscreen');
    fullscreenBtn.setAttribute('title', isFullscreen ? 'Exit fullscreen' : 'View fullscreen');
  }
  fullscreenBtn.addEventListener('click', () => {
    if (document.fullscreenElement === wrapper) { document.exitFullscreen?.(); }
    else { wrapper.requestFullscreen?.(); }
  });
  document.addEventListener('fullscreenchange', () => { syncFullscreenButton(); setTimeout(render, 60); });
  window.addEventListener('resize', () => render());
  svg.addEventListener('click', () => {
    if (state.country !== 'ALL') { state.country = 'ALL'; updateCountryInput(); render(); }
  });
  initControls();
  syncFullscreenButton();
  render();
})();
</script>
</body>
</html>
