,{"id":"SUR","name":"Suriname","region":"Latin America & Caribbean","income":"Upper middle income","v2021":147616111.52,"v2024":160306201.69,"change":12690090.17,"pctChange":0.08596684},{"id":"SVK","name":"Slovak Republic","region":"Europe & Central Asia","income":"High income","v2021":2428848211.81,"v2024":2954562147.72,"change":525713935.91,"pctChange":0.21644578},{"id":"SVN","name":"Slovenia","region":"Europe & Central Asia","income":"High income","v2021":826522548.91,"v2024":907209654.86,"change":80687105.95,"pctChange":0.09762239},{"id":"SWE","name":"Sweden","region":"Europe & Central Asia","income":"High income","v2021":3262227168.88,"v2024":4426228371.92,"change":1164001203.04,"pctChange":0.35681182},{"id":"SWZ","name":"Eswatini","region":"Sub-Saharan Africa","income":"Lower middle income","v2021":132168224.64,"v2024":33346090.71,"change":-98822133.92,"pctChange":-0.74769964},{"id":"SXM","name":"Sint Maarten (Dutch part)","region":"Latin America & Caribbean","income":"High income","v2021":46482043.83,"v2024":48417966.28,"change":1935922.46,"pctChange":0.04164882},{"id":"SYC","name":"Seychelles","region":"Sub-Saharan Africa","income":"High income","v2021":9512244.93,"v2024":11945618.22,"change":2433373.29,"pctChange":0.25581483},{"id":"THA","name":"Thailand","region":"East Asia & Pacific","income":"Upper middle income","v2021":8679453300.98,"v2024":9456168895.29,"change":776715594.31,"pctChange":0.089489},{"id":"TJK","name":"Tajikistan","region":"Europe & Central Asia","income":"Lower middle income","v2021":2921713106.98,"v2024":6801890973.46,"change":3880177866.48,"pctChange":1.3280489},{"id":"TLS","name":"Timor-Leste","region":"East Asia & Pacific","income":"Lower middle income","v2021":150041331.42,"v2024":219567997.25,"change":69526665.83,"pctChange":0.46338342},{"id":"TON","name":"Tonga","region":"East Asia & Pacific","income":"Upper middle income","v2021":215673174.66,"v2024":253796161.46,"change":38122986.8,"pctChange":0.17676277},{"id":"TTO","name":"Tr