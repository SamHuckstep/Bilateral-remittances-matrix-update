<script>
const data = JSON.parse(document.getElementById('vizData').textContent);
const countries = data.countries;
const summary = data.summary;
const baselineYear = 2021;
const comparisonYear = 2024;
const regionColors = {
  'East Asia & Pacific':'#2D99B5',
  'Europe & Central Asia':'#0B4C5B',
  'Latin America & Caribbean':'#FFB52C',
  'Middle East & North Africa':'#85A5AD',
  'North America':'#394649',
  'South Asia':'#00896C',
  'Sub-Saharan Africa':'#BFDEE0',
  'Unclassified':'#DFE0E2'
};
const state = { income:'ALL', activeRegion:null, selectedCountry:'ALL' };
const root = document.getElementById('vizRoot');
const scatterSvg = document.getElementById('scatterSvg');
const tooltip = document.getElementById('tooltip');
const incomeSelect = document.getElementById('incomeSelect');
const countrySelect = document.getElementById('countrySelect');
const countryInput = document.getElementById('countryInput');
const countryMenu = document.getElementById('countryMenu');
const regionLegend = document.getElementById('regionLegend');
const fullscreenBtn = document.getElementById('fullscreenBtn');
let countryMenuOpen = false;
let userIsTyping = false;
let resizeTimer = null;

function fmtPct(v, digits=1) { if(!Number.isFinite(v)) return 'N/A'; return (v*100).toFixed(digits) + '%'; }
function fmtPp(v, digits=1) { if(!Number.isFinite(v)) return 'N/A'; const sign = v>0 ? '+' : ''; return sign + v.toFixed(digits) + ' pp'; }
function fmtMoney(v) {
  if(!Number.isFinite(v)) return 'N/A';
  const abs = Math.abs(v);
  if(abs >= 1e12) return '$' + (v/1e12).toFixed(abs>=10e12?1:2) + 'tn';
  if(abs >= 1e9) return '$' + (v/1e9).toFixed(abs>=10e9?1:2) + 'bn';
  if(abs >= 1e6) return '$' + (v/1e6).toFixed(abs>=10e6?1:2) + 'mn';
  return '$' + Math.round(v).toLocaleString();
}
function cleanLagLabel(lag, yr) {
  if(!lag) return yr ? String(yr) : 'N/A';
  if(lag === 'target_year') return String(yr);
  return yr ? `${yr} (latest available)` : 'latest available';
}
function changeClass(v) { return v > 0 ? 'up' : v < 0 ? 'down' : ''; }
function clamp(x, lo, hi) { return Math.max(lo, Math.min(hi, x)); }
function makeLinearScale(d0,d1,r0,r1) { return v => r0 + ((v-d0)/(d1-d0 || 1))*(r1-r0); }
function niceDomainMax(maxv) {
  const pct = maxv*100;
  if(pct <= 5) return 0.05;
  if(pct <= 10) return 0.10;
  if(pct <= 25) return 0.25;
  if(pct <= 40) return 0.40;
  if(pct <= 45) return 0.45;
  if(pct <= 50) return 0.50;
  return Math.ceil(pct/10)*10/100;
}
const globalDomainMax = niceDomainMax(summary.maxRatio);

function radiusFactory(values, minR=3.3, maxR=18) {
  const clean = values.filter(v => Number.isFinite(v) && v>0);
  const min = Math.min(...clean), max = Math.max(...clean);
  return function(v) {
    if(!Number.isFinite(v) || v<=0 || max<=min) return minR;
    const t=(v-min)/(max-min);
    const minA=minR*minR, maxA=maxR*maxR;
    return Math.sqrt(minA + t*(maxA-minA));
  }
}
const bubbleRadius = radiusFactory(countries.map(d=>d.total2024));

function filteredCountries(includeRegionMute=true) {
  return countries.filter(d => state.income === 'ALL' || d.income === state.income);
}
function visibleCountryOptions() {
  return countries.filter(d => state.income === 'ALL' || d.income === state.income).sort((a,b)=>a.name.localeCompare(b.name));
}
function selectedProfile() { return countries.find(d => d.id === state.selectedCountry); }

function initControls() {
  const opts = [['ALL','All income groups'], ...summary.incomes.map(x=>[x,x])];
  incomeSelect.innerHTML = opts.map(([v,l]) => `<option value="${escapeAttr(v)}">${escapeHtml(l)}</option>`).join('');
  incomeSelect.addEventListener('change', () => {
    state.income = incomeSelect.value;
    if(state.selectedCountry !== 'ALL') {
      const stillVisible = visibleCountryOptions().some(d => d.id === state.selectedCountry);
      if(!stillVisible) clearSelection();
    }
    render();
  });

  countryInput.addEventListener('focus', openCountryMenu);
  countryInput.addEventListener('click', openCountryMenu);
  countryInput.addEventListener('input', () => {
    userIsTyping = true;
    renderCountryOptions(countryInput.value.trim().toLowerCase());
  });
  document.addEventListener('click', (e) => {
    if(!countrySelect.contains(e.target)) closeCountryMenu();
  });
  countryInput.addEventListener('keydown', (e) => {
    if(e.key === 'Escape') { closeCountryMenu(); countryInput.blur(); }
  });
}
function escapeHtml(str) { return String(str ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
function escapeAttr(str) { return escapeHtml(str).replace(/`/g,'&#96;'); }
function openCountryMenu() {
  countryMenuOpen = true; userIsTyping = false;
  countrySelect.classList.add('open');
  countryInput.setAttribute('aria-expanded','true');
  if(state.selectedCountry !== 'ALL') {
    const d = selectedProfile();
    countryInput.value = '';
    countryInput.placeholder = d ? d.name : 'All recipient countries';
  }
  renderCountryOptions('');
}
function closeCountryMenu() {
  countryMenuOpen = false; userIsTyping = false;
  countrySelect.classList.remove('open');
  countryInput.setAttribute('aria-expanded','false');
  syncCountryInput();
}
function syncCountryInput() {
  if(state.selectedCountry === 'ALL') {
    countryInput.value = '';
    countryInput.placeholder = 'All recipient countries';
  } else {
    const d = selectedProfile();
    countryInput.value = d ? d.name : '';
    countryInput.placeholder = d ? d.name : 'All recipient countries';
  }
}
function renderCountryOptions(query='') {
  const options = visibleCountryOptions();
  const filtered = query ? options.filter(d => d.name.toLowerCase().includes(query) || d.id.toLowerCase().includes(query)) : options;
  const allBtn = `<button class="select-option ${state.selectedCountry==='ALL'?'active':''}" type="button" role="option" data-id="ALL">All recipient countries</button>`;
  const body = filtered.length ? filtered.map(d => `<button class="select-option ${state.selectedCountry===d.id?'active':''}" type="button" role="option" data-id="${escapeAttr(d.id)}">${escapeHtml(d.name)}</button>`).join('') : '<div class="select-empty">No matching countries</div>';
  countryMenu.innerHTML = allBtn + body;
  countryMenu.querySelectorAll('.select-option').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = btn.dataset.id;
      if(id === 'ALL') clearSelection(); else selectCountry(id);
      closeCountryMenu();
    });
  });
}

function selectCountry(id) {
  state.selectedCountry = id;
  syncCountryInput();
  render();
}
function clearSelection() {
  state.selectedCountry = 'ALL';
  syncCountryInput();
  render();
}

function renderLegend() {
  const regs = summary.regions.slice();
  regionLegend.innerHTML = regs.map(r => `<button class="legend-item ${state.activeRegion===r?'active':''} ${state.activeRegion && state.activeRegion!==r?'muted':''}" type="button" data-region="${escapeAttr(r)}"><span class="swatch" style="--swatch:${regionColors[r] || '#DFE0E2'}"></span>${escapeHtml(r)}</button>`).join('');
  regionLegend.querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', () => {
      const r = btn.dataset.region;
      state.activeRegion = state.activeRegion === r ? null : r;
      render();
    });
  });
}


function render() {
  renderLegend();
  renderScatter();
}

function renderScatter() {
  const wrap = scatterSvg.parentElement;
  const width = Math.max(320, wrap.clientWidth || 900);
  const height = Math.max(320, wrap.clientHeight || 430);
  const margin = {top:22,right:26,bottom:54,left:60};
  if(width < 520) { margin.left = 48; margin.right = 14; margin.bottom = 48; margin.top = 20; }
  const innerW = width - margin.left - margin.right;
  const innerH = height - margin.top - margin.bottom;
  scatterSvg.setAttribute('viewBox', `0 0 ${width} ${height}`);
  scatterSvg.innerHTML = '';
  const bg = document.createElementNS('http://www.w3.org/2000/svg','rect');
  bg.setAttribute('x',0); bg.setAttribute('y',0); bg.setAttribute('width',width); bg.setAttribute('height',height); bg.setAttribute('fill','#fff');
  bg.addEventListener('click', () => { if(state.selectedCountry !== 'ALL') clearSelection(); });
  scatterSvg.appendChild(bg);
  const g = document.createElementNS('http://www.w3.org/2000/svg','g');
  g.setAttribute('transform',`translate(${margin.left},${margin.top})`);
  scatterSvg.appendChild(g);
  const x = makeLinearScale(0, globalDomainMax, 0, innerW);
  const y = makeLinearScale(0, globalDomainMax, innerH, 0);
  const ticks = [];
  const step = globalDomainMax <= .25 ? .05 : .10;
  for(let t=0; t<=globalDomainMax+1e-9; t+=step) ticks.push(Math.round(t*1000)/1000);

  const grid = document.createElementNS('http://www.w3.org/2000/svg','g');
  g.appendChild(grid);
  ticks.forEach(t => {
    const xv=x(t), yv=y(t);
    grid.appendChild(line(xv,0,xv,innerH,'grid-line'));
    grid.appendChild(line(0,yv,innerW,yv,'grid-line'));
  });
  g.appendChild(line(0,innerH,innerW,0,'parity-line'));

  // contextual labels, offset from parity line
  const q1 = text('Higher in 2024', x(globalDomainMax*.64), y(globalDomainMax*.83), 'quadrant-label');
  q1.setAttribute('text-anchor','middle'); g.appendChild(q1);
  const q2 = text('Higher in 2021', x(globalDomainMax*.82), y(globalDomainMax*.62), 'quadrant-label');
  q2.setAttribute('text-anchor','middle'); g.appendChild(q2);

  // axes
  const axis = document.createElementNS('http://www.w3.org/2000/svg','g'); axis.setAttribute('class','axis'); g.appendChild(axis);
  axis.appendChild(line(0,innerH,innerW,innerH,'')); axis.appendChild(line(0,0,0,innerH,''));
  ticks.forEach(t => {
    const xv=x(t), yv=y(t);
    axis.appendChild(line(xv,innerH,xv,innerH+5,''));
    const tx=text(fmtPct(t,0),xv,innerH+19,'small-text'); tx.setAttribute('text-anchor','middle'); axis.appendChild(tx);
    axis.appendChild(line(-5,yv,0,yv,''));
    const ty=text(fmtPct(t,0),-9,yv+3,'small-text'); ty.setAttribute('text-anchor','end'); axis.appendChild(ty);
  });
  const xt=text('2021 remittance receipts as a % current US$ GNI', innerW/2, innerH+42, 'axis-title'); xt.setAttribute('text-anchor','middle'); axis.appendChild(xt);
  const yt=text('2024 remittance receipts as a % current US$ GNI', -43, innerH/2, 'axis-title'); yt.setAttribute('text-anchor','middle'); yt.setAttribute('transform',`rotate(-90 -43 ${innerH/2})`); axis.appendChild(yt);

  const points = filteredCountries().slice().sort((a,b)=>{
    const as = state.selectedCountry !== 'ALL' && a.id === state.selectedCountry;
    const bs = state.selectedCountry !== 'ALL' && b.id === state.selectedCountry;
    if(as !== bs) return as ? 1 : -1;
    return a.total2024-b.total2024;
  });
  const pLayer = document.createElementNS('http://www.w3.org/2000/svg','g'); g.appendChild(pLayer);
  points.forEach(d => {
    const isSelected = state.selectedCountry !== 'ALL' && state.selectedCountry === d.id;
    const mutedBySelection = state.selectedCountry !== 'ALL' && state.selectedCountry !== d.id;
    const mutedByRegion = !isSelected && state.activeRegion && state.activeRegion !== d.region;
    const c = circle(x(d.ratio2021), y(d.ratio2024), bubbleRadius(d.total2024), 'point');
    c.dataset.id = d.id;
    c.setAttribute('fill', mutedBySelection || mutedByRegion ? '#DFE0E2' : (regionColors[d.region] || '#DFE0E2'));
    if(isSelected) c.classList.add('selected');
    if(mutedBySelection || mutedByRegion) c.classList.add(mutedBySelection ? 'muted':'context-muted');
    c.addEventListener('mouseenter', ev => showTooltip(d, ev));
    c.addEventListener('mousemove', ev => positionTooltip(ev));
    c.addEventListener('mouseleave', hideTooltip);
    c.addEventListener('click', ev => { ev.stopPropagation(); selectCountry(d.id); });
    pLayer.appendChild(c);
  });
}
function line(x1,y1,x2,y2,cls) { const el=document.createElementNS('http://www.w3.org/2000/svg','line'); el.setAttribute('x1',x1); el.setAttribute('y1',y1); el.setAttribute('x2',x2); el.setAttribute('y2',y2); if(cls) { el.setAttribute('class',cls); } else { el.setAttribute('stroke','#D9E1E4'); el.setAttribute('stroke-width','1'); el.setAttribute('vector-effect','non-scaling-stroke'); } return el; }
function circle(cx,cy,r,cls) { const el=document.createElementNS('http://www.w3.org/2000/svg','circle'); el.setAttribute('cx',cx); el.setAttribute('cy',cy); el.setAttribute('r',r); if(cls) el.setAttribute('class',cls); return el; }
function text(value,x,y,cls) { const el=document.createElementNS('http://www.w3.org/2000/svg','text'); el.textContent=value; el.setAttribute('x',x); el.setAttribute('y',y); if(cls) el.setAttribute('class',cls); return el; }

function showTooltip(d, ev) {
  const change = (d.ratio2024-d.ratio2021)*100;
  tooltip.innerHTML = `<strong>${escapeHtml(d.name)}</strong><div class="tooltip-grid">
    <span>Income group</span><b>${escapeHtml(d.income)}</b>
    <span>2021</span><b>${fmtPct(d.ratio2021)}</b>
    <span>2024</span><b>${fmtPct(d.ratio2024)}</b>
    <span>Change</span><b>${fmtPp(change)}</b>
    <span>2024 receipts</span><b>${fmtMoney(d.total2024)}</b>
  </div>`;
  tooltip.hidden = false; tooltip.style.opacity = 1; positionTooltip(ev);
}
function positionTooltip(ev) {
  const pad = 12;
  const rect = tooltip.getBoundingClientRect();
  let left = ev.clientX + 14;
  let top = ev.clientY + 14;
  if(left + rect.width + pad > window.innerWidth) left = ev.clientX - rect.width - 14;
  if(top + rect.height + pad > window.innerHeight) top = ev.clientY - rect.height - 14;
  tooltip.style.left = Math.max(pad,left) + 'px';
  tooltip.style.top = Math.max(pad,top) + 'px';
}
function hideTooltip() { tooltip.style.opacity = 0; tooltip.hidden = true; }

function syncFullscreenButton() {
  const isFullscreen = document.fullscreenElement === root;
  fullscreenBtn.setAttribute('aria-label', isFullscreen ? 'Exit fullscreen' : 'View fullscreen');
  fullscreenBtn.setAttribute('title', isFullscreen ? 'Exit fullscreen' : 'View fullscreen');
}
fullscreenBtn.addEventListener('click', () => {
  if(document.fullscreenElement === root) document.exitFullscreen?.(); else root.requestFullscreen?.();
});
document.addEventListener('fullscreenchange', () => { syncFullscreenButton(); window.setTimeout(render, 80); });
window.addEventListener('resize', () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(render, 120); });

initControls(); syncCountryInput(); syncFullscreenButton(); render();
</script>
</body>
</html>

