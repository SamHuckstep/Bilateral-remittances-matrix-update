const state = {year:'2024',metric:'usd'};
const fmtInt=new Intl.NumberFormat('en-GB',{maximumFractionDigits:0});const fmt1=new Intl.NumberFormat('en-GB',{minimumFractionDigits:1,maximumFractionDigits:1});
function escapeHtml(value){return String(value??'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'","&#039;")}
function isChange(){return state.year==='change'}
function formatMoney(value){if(value==null||Number.isNaN(value))return'N/A';const sign=value<0?'-':'';const abs=Math.abs(value);if(abs>=1e12)return`${sign}${fmt1.format(abs/1e12)}tn`;if(abs>=1e9)return`${sign}${fmt1.format(abs/1e9)}bn`;if(abs>=1e6)return`${sign}${fmt1.format(abs/1e6)}m`;if(abs>=1e3)return`${sign}${fmt1.format(abs/1e3)}k`;return`${sign}${fmtInt.format(abs)}`}
function formatSignedMoney(value){if(value==null||Number.isNaN(value))return'N/A';const sign=value>0?'+':value<0?'-':'';return`${sign}$${formatMoney(Math.abs(value))}`}
function formatPpChange(value){if(value==null||Number.isNaN(value)||!Number.isFinite(value))return'N/A';const sign=value>0?'+':'';return`${sign}${(value*100).toFixed(1)}pp`}
function formatCell(value,share,changePp){if(isChange())return state.metric==='pct'?formatPpChange(changePp):formatSignedMoney(value);return state.metric==='pct'?`${(share*100).toFixed(1)}%`:`$${formatMoney(value)}`}
function groupLabel(id){return vizData.groups.find(g=>g.id===id)?.label||id}
function baseCell(year,rg,sg){return vizData.cells[`${year}|${rg}|${sg}`]||{value:0,share:0,corridors:0}}
function shareChange(currentValue,currentTotal,previousValue,previousTotal){const currentShare=currentTotal?currentValue/currentTotal:0;const previousShare=previousTotal?previousValue/previousTotal:0;return currentShare-previousShare}
function itemPpChange(item){return shareChange(item.currentValue||0,vizData.globalTotals['2024']||0,item.previousValue||0,vizData.globalTotals['2021']||0)}
function changeScaleDenominator(){const groups=vizData.groups;let max=0;groups.forEach(rg=>groups.forEach(sg=>{const diff=Math.abs(baseCell('2024',rg.id,sg.id).value-baseCell('2021',rg.id,sg.id).value);if(diff>max)max=diff}));return max||1}
function cellDatum(rg,sg){if(!isChange())return baseCell(state.year,rg,sg);const c24=baseCell('2024',rg,sg);const c21=baseCell('2021',rg,sg);const value=c24.value-c21.value;const key=`change|${rg}|${sg}`;const totalCount=vizData.changeTopCorridors?.[key]?.totalCount||0;return{year:'change',recipientGroup:rg,sourceGroup:sg,value:value,share:Math.abs(value)/changeScaleDenominator(),changePp:(c24.share||0)-(c21.share||0),corridors:totalCount}}
function rowDatum(rg){if(!isChange()){const value=vizData.rowTotals[`${state.year}|${rg}`]||0;const total=vizData.globalTotals[state.year]||0;return{value:value,share:total?value/total:0,changePp:null}}const v24=vizData.rowTotals[`2024|${rg}`]||0;const v21=vizData.rowTotals[`2021|${rg}`]||0;return{value:v24-v21,share:Math.abs(v24-v21)/changeScaleDenominator(),changePp:shareChange(v24,vizData.globalTotals['2024']||0,v21,vizData.globalTotals['2021']||0)}}
function colDatum(sg){if(!isChange()){const value=vizData.colTotals[`${state.year}|${sg}`]||0;const total=vizData.globalTotals[state.year]||0;return{value:value,share:total?value/total:0,changePp:null}}const v24=vizData.colTotals[`2024|${sg}`]||0;const v21=vizData.colTotals[`2021|${sg}`]||0;return{value:v24-v21,share:Math.abs(v24-v21)/changeScaleDenominator(),changePp:shareChange(v24,vizData.globalTotals['2024']||0,v21,vizData.globalTotals['2021']||0)}}
function globalDatum(){if(!isChange()){const value=vizData.globalTotals[state.year]||0;return{value:value,share:1,changePp:null}}const v24=vizData.globalTotals['2024']||0;const v21=vizData.globalTotals['2021']||0;return{value:v24-v21,share:1,changePp:0}}
function cellColour(share){const maxShare=isChange()?1:(vizData.maxShare[state.year]||1);const t=Math.max(0,Math.min(1,Math.sqrt(Math.abs(share)/maxShare)));const light=[243,246,247],mid=[191,222,224],high=[11,76,91];let a,b,u;if(t<.55){a=light;b=mid;u=t/.55}else{a=mid;b=high;u=(t-.55)/.45}const rgb=a.map((v,i)=>Math.round(v+(b[i]-v)*u));return{bg:`rgb(${rgb[0]},${rgb[1]},${rgb[2]})`,fg:t>.66?'#FFFFFF':'#1A272A'}}
function cellKey(rg,sg){return`${state.year}|${rg}|${sg}`}
function updateNote(){const note=document.getElementById('noteText');if(!note)return;note.textContent=isChange()?`Rows are recipient groups; columns are source groups. Change shows 2024 minus 2021. US$ displays absolute change; % displays percentage change from 2021 to 2024. Shading reflects the absolute size of the change.`:`Rows are recipient groups; columns are source groups. Values are modelled bilateral remittance flows in current US dollars. Shading reflects each cell's share of the selected year's global total.`}
function render(){updateNote();const grid=document.getElementById('heatGrid');const groups=vizData.groups;const grand=globalDatum();const parts=[];parts.push(`<div class="corner" aria-label="Rows show recipient income group; columns show source income group"><svg class="corner-line" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true"><line x1="0" y1="0" x2="100" y2="100"></line></svg><span class="corner-source">Source income group</span><span class="corner-recipient">Recipient income group</span></div>`);groups.forEach(g=>parts.push(`<div class="col-header"><span class="header-label">${escapeHtml(g.label)}</span></div>`));parts.push(`<div class="total-header"><span class="total-label">Total</span></div>`);groups.forEach(rg=>{parts.push(`<div class="row-header"><span class="row-label">${escapeHtml(rg.label)}</span></div>`);groups.forEach(sg=>{const d=cellDatum(rg.id,sg.id);const colour=cellColour(d.share||0);const value=formatCell(d.value,d.share,d.changePp);const title=isChange()?`${sg.label} to ${rg.label}: ${value} change, 2024 minus 2021. Click to see largest corridor changes.`:`${sg.label} to ${rg.label}: ${value}. Click to see largest corridors.`;parts.push(`<button class="cell" type="button" style="--cell-bg:${colour.bg};--cell-fg:${colour.fg}" data-rg="${escapeHtml(rg.id)}" data-sg="${escapeHtml(sg.id)}" title="${escapeHtml(title)}" aria-label="${escapeHtml(title)}"><span class="cell-value">${escapeHtml(value)}</span></button>`)});const rv=rowDatum(rg.id);parts.push(`<div class="total-cell"><span class="total-value">${escapeHtml(formatCell(rv.value,rv.share,rv.changePp))}</span></div>`)});parts.push(`<div class="total-header"><span class="total-label">Total</span></div>`);groups.forEach(sg=>{const cv=colDatum(sg.id);parts.push(`<div class="total-cell"><span class="total-value">${escapeHtml(formatCell(cv.value,cv.share,cv.changePp))}</span></div>`)});parts.push(`<div class="grand-cell"><span class="grand-value">${escapeHtml(formatCell(grand.value,grand.share,grand.changePp))}</span></div>`);grid.innerHTML=parts.join('');grid.querySelectorAll('.cell').forEach(btn=>btn.addEventListener('click',()=>openPopup(btn.dataset.rg,btn.dataset.sg)))}
function openPopup(rg,sg){const d=cellDatum(rg,sg);const key=isChange()?`change|${rg}|${sg}`:cellKey(rg,sg);const top=(isChange()?vizData.changeTopCorridors?.[key]:vizData.topCorridors[key])||{items:[],totalCount:0,shownCount:0,remainingValue:0};const popup=document.getElementById('popup');document.getElementById('popupTitle').textContent=isChange()?`${groupLabel(sg)} to ${groupLabel(rg)}: change`:`${groupLabel(sg)} to ${groupLabel(rg)}`;document.getElementById('popupSub').textContent=isChange()?`2024 minus 2021 • ${formatCell(d.value,d.share,d.changePp)} across ${fmtInt.format(d.corridors||0)} corridors with non-zero change`:`${state.year} • ${formatCell(d.value,d.share)} across ${fmtInt.format(d.corridors||0)} corridors`;const list=document.getElementById('corridorList');if(!top.items.length){list.innerHTML=isChange()?'<div class="remaining">No corridor changes in this cell.</div>':'<div class="remaining">No positive corridors in this cell.</div>'}else{const rows=top.items.map(item=>{if(isChange()){const shownValue=state.metric==='pct'?formatPpChange(itemPpChange(item)):formatSignedMoney(item.value);const meta=`${formatSignedMoney(item.value)}; 2021: $${formatMoney(item.previousValue)}; 2024: $${formatMoney(item.currentValue)}`;return`<div class="corridor-row"><div><div class="corridor-route">${escapeHtml(item.source)} → ${escapeHtml(item.recipient)}</div><div class="corridor-meta">${escapeHtml(meta)}</div></div><div class="corridor-value">${escapeHtml(shownValue)}</div></div>`}const shareOfCell=d.value?item.value/d.value:0;return`<div class="corridor-row"><div><div class="corridor-route">${escapeHtml(item.source)} → ${escapeHtml(item.recipient)}</div><div class="corridor-meta">${(shareOfCell*100).toFixed(1)}% of this cell</div></div><div class="corridor-value">$${escapeHtml(formatMoney(item.value))}</div></div>`});if(top.totalCount>top.shownCount){rows.push(isChange()?`<div class="remaining">${fmtInt.format(top.totalCount-top.shownCount)} further corridors account for ${formatSignedMoney(top.remainingValue)} in net change.</div>`:`<div class="remaining">${fmtInt.format(top.totalCount-top.shownCount)} further corridors account for $${formatMoney(top.remainingValue)}.</div>`)}list.innerHTML=rows.join('')}popup.classList.add('open');document.getElementById('popupClose').focus()}
function closePopup(){document.getElementById('popup').classList.remove('open')}
function setupToggle(id,prop){const group=document.getElementById(id);group.addEventListener('click',event=>{const btn=event.target.closest('button');if(!btn||!group.contains(btn))return;state[prop]=btn.dataset[prop];group.querySelectorAll('button').forEach(b=>b.setAttribute('aria-pressed',b===btn?'true':'false'));render()})}
setupToggle('yearToggle','year');setupToggle('metricToggle','metric');document.getElementById('popupClose').addEventListener('click',closePopup);document.getElementById('popup').addEventListener('click',event=>{if(event.target.id==='popup')closePopup()});document.addEventListener('keydown',event=>{if(event.key==='Escape')closePopup()});
const wrapper=document.querySelector('.viz-wrapper');const fullscreenBtn=document.getElementById('fullscreenBtn');function syncFullscreenButton(){const isFullscreen=document.fullscreenElement===wrapper;fullscreenBtn.setAttribute('aria-label',isFullscreen?'Exit fullscreen':'View fullscreen');fullscreenBtn.setAttribute('title',isFullscreen?'Exit fullscreen':'View fullscreen')}fullscreenBtn.addEventListener('click',()=>{if(document.fullscreenElement===wrapper){document.exitFullscreen?.()}else{wrapper.requestFullscreen?.()}});document.addEventListener('fullscreenchange',()=>{syncFullscreenButton();requestAnimationFrame(render)});syncFullscreenButton();render();
