let countrySearch = '';
function esc(value){return String(value ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#039;');}
function fmtMoney(v){
  if(v==null || !Number.isFinite(v)) return 'N/A';
  const sign = v < 0 ? '-' : ''; const abs = Math.abs(v);
  if(abs >= 1e12) return sign + '$' + (abs/1e12).toFixed(abs>=10e12?0:1) + 'tn';
  if(abs >= 1e9) return sign + '$' + (abs/1e9).toFixed(abs>=10e9?0:1) + 'bn';
  if(abs >= 1e6) return sign + '$' + (abs/1e6).toFixed(abs>=10e6?0:1) + 'm';
  return sign + '$' + Math.round(abs).toLocaleString();
}
function fmtNumber(v){ if(v==null || !Number.isFinite(v)) return 'N/A'; return Math.round(v).toLocaleString(); }
function fmtMigrants(v){
  if(v==null || !Number.isFinite(v)) return 'N/A';
  const sign = v < 0 ? '−' : '';
  const abs = Math.abs(v);
  if(abs >= 1e6){
    const val = abs/1e6;
    const dec = val >= 10 || Math.abs(val - Math.round(val)) < 0.05 ? 0 : 1;
    return sign + val.toFixed(dec) + 'm';
  }
  if(abs >= 1e3){
    const val = abs/1e3;
    const dec = val >= 10 || Math.abs(val - Math.round(val)) < 0.05 ? 0 : 1;
    return sign + val.toFixed(dec) + 'k';
  }
  return sign + Math.round(abs).toLocaleString();
}
function fmtMigrantsSigned(v){ if(v==null || !Number.isFinite(v)) return 'N/A'; const sign = v > 0 ? '+' : (v < 0 ? '−' : ''); return sign + fmtMigrants(Math.abs(v)); }
function fmtPct(v){ if(v==null || !Number.isFinite(v)) return 'N/A'; const sign=v>0?'+':''; const val=v*100; const dec=Math.abs(val)>=10?0:1; return sign+val.toFixed(dec)+'%'; }
function fmtPctAxis(v){ if(v==null || !Number.isFinite(v)) return ''; const val=v*100; const dec=Math.abs(val)>=10?0:1; return val.toFixed(dec)+'%'; }
function fmtShare(v){ if(v==null || !Number.isFinite(v)) return 'N/A'; return (v*100).toFixed(v < 0.01 ? 2 : 1)+'%'; }
function valueFormatterX(){ return state.metric === 'migration' ? fmtMigrants : fmtMoney; }
function xMetric(d){ return state.metric === 'migration' ? d.migrants2021 : d.avgGni2021; }
function yMetric(d){ return state.metric === 'migration' ? d.migrantChangePct : d.changePct; }
function xDomain(){ return state.metric === 'migration' ? paddedLogDomain(summary.migrantDomainMin, summary.migrantDomainMax) : paddedLogDomain(summary.domainMin, summary.domainMax); }
function yRawDomain(){ return state.metric === 'migration' ? [summary.migrantChangeMin, summary.migrantChangeMax] : [summary.gniChangeMin, summary.gniChangeMax]; }
function create(tag, attrs={}, text=null){ const el = document.createElementNS('http://www.w3.org/2000/svg', tag); Object.entries(attrs).forEach(([k,v])=>el.setAttribute(k, v)); if(text !== null) el.textContent = text; return el; }
function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }
function log10(v){ return Math.log(v) / Math.LN10; }
function paddedLogDomain(minVal, maxVal){ return [Math.pow(10, Math.floor(log10(minVal))), Math.pow(10, Math.ceil(log10(maxVal)))]; }
const stockDomain = [summary.stockMin, summary.stockMax];
const migrationChangeAbsDomain = [0, Math.max(...countries.map(d => Math.abs(d.migrantChange || 0)).filter(v => Number.isFinite(v)), 1)];
function xScale(v, plot, domain){ const t=(log10(v)-log10(domain[0]))/(log10(domain[1])-log10(domain[0])); return plot.left + t * plot.width; }
function yScaleLinear(v, plot, domain){ const t=(v-domain[0])/(domain[1]-domain[0]); return plot.top + (1-t) * plot.height; }
function bubbleRadius(d, width){
  if(state.metric === 'migration'){
    const rMin = width < 520 ? 3.8 : 4.4;
    const rMax = width < 520 ? 14.5 : 22.0;
    const min = migrationChangeAbsDomain[0], max = migrationChangeAbsDomain[1];
    const value = Number.isFinite(d.migrantChange) ? Math.abs(d.migrantChange) : 0;
    const t = max === min ? 0.5 : (clamp(value, min, max) - min) / (max - min);
    return Math.sqrt(rMin*rMin + t*(rMax*rMax - rMin*rMin));
  }
  const rMin = width < 520 ? 2.9 : 3.3;
  const rMax = width < 520 ? 16.0 : 24.0;
  const min = stockDomain[0], max = stockDomain[1];
  const value = Number.isFinite(d.migrants2024) && d.migrants2024 > 0 ? d.migrants2024 : min;
  const t = max === min ? 0.5 : (clamp(value, min, max) - min) / (max - min);
  return Math.sqrt(rMin*rMin + t*(rMax*rMax - rMin*rMin));
}
function logTicks(domain){
  const minP = Math.floor(log10(domain[0]));
  const maxP = Math.ceil(log10(domain[1]));
  const ticks = [];
  for(let p=minP; p<=maxP; p++){
    [1,2,5].forEach(m=>{ const v=m*Math.pow(10,p); if(v>=domain[0]*0.999 && v<=domain[1]*1.001) ticks.push(v); });
  }
  return ticks.filter((v,i)=> i===0 || v/ticks[i-1] >= 1.9);
}
function niceStep(range, target){
  const rough = Math.abs(range) / Math.max(1, target);
  if(!Number.isFinite(rough) || rough===0) return 0.1;
  const power = Math.pow(10, Math.floor(Math.log10(rough)));
  const mult = rough / power;
  const nice = mult <= 1 ? 1 : mult <= 2 ? 2 : mult <= 5 ? 5 : 10;
  return nice * power;
}
function linearTicks(domain, target=6){
  const min=domain[0], max=domain[1];
  const step = niceStep(max-min, target);
  const start = Math.floor(min/step)*step;
  const end = Math.ceil(max/step)*step;
  const ticks=[];
  for(let v=start; v<=end + step*0.5; v+=step){ ticks.push(+v.toFixed(10)); }
  return ticks;
}
function yDomain(rows){
  const values = rows.map(yMetric).filter(v => Number.isFinite(v));
  let min = Math.min(...values, 0);
  let max = Math.max(...values, 0);
  const span = max - min || 0.1;
  min -= span*0.08; max += span*0.08;
  if(min > 0) min = 0;
  if(max < 0) max = 0;
  if(state.metric === 'gni'){
    min = Math.max(min, -0.30);
    max = Math.min(max, 0.70);
  } else {
    if(Math.abs(min) > 2.5) min = Math.max(min, -2.5);
    if(Math.abs(max) > 2.5) max = Math.min(max, 2.5);
  }
  return [min, max];
}
function filteredCountries(){ return countries.filter(d => (state.region==='ALL' || d.region===state.region)); }
function getSelectedCountry(){ return countries.find(d=>d.id===state.country) || null; }
function validateCountry(){ if(state.country==='ALL') return; if(!filteredCountries().some(d=>d.id===state.country)){ state.country='ALL'; closePopup(); updateCountryInput(); } }
function countryOptions(){ return [{id:'ALL', name:'All countries'}].concat(filteredCountries().slice().sort((a,b)=>a.name.localeCompare(b.name))); }
function openCountryMenu(){ countrySelect.classList.add('open'); countryMenu.classList.add('open'); countryInput.setAttribute('aria-expanded','true'); renderCountryMenu(); }
function closeCountryMenu(){ countrySelect.classList.remove('open'); countryMenu.classList.remove('open'); countryInput.setAttribute('aria-expanded','false'); updateCountryInput(); }
function updateCountryInput(){ const selected=getSelectedCountry(); countryInput.value=''; countryInput.placeholder = selected ? selected.name : 'All countries'; }
function renderCountryMenu(){
  const q = (countrySearch||'').trim().toLowerCase();
  const items = countryOptions().filter(d=> !q || d.name.toLowerCase().includes(q));
  countryMenu.innerHTML = items.length ? items.map(d=>`<button type="button" class="select-option${d.id===state.country?' active':''}" role="option" data-id="${esc(d.id)}">${esc(d.name)}</button>`).join('') : '<div class="select-empty">No matches</div>';
  countryMenu.querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => { state.country = btn.dataset.id; closeCountryMenu(); render(); if(state.country !== 'ALL') { const d=getSelectedCountry(); if(d) openCountryPopup(d); } else closePopup(); }));
}
function renderRegionSelect(){ const regions = ['ALL'].concat(summary.regions); regionSelect.innerHTML = regions.map(r=>`<option value="${esc(r)}">${r==='ALL'?'All regions':esc(r)}</option>`).join(''); regionSelect.value = state.region; }
function renderMetricToggle(){ metricToggle.querySelectorAll('button[data-metric]').forEach(btn => { btn.setAttribute('aria-pressed', btn.dataset.metric === state.metric ? 'true' : 'false'); }); }
function renderLegend(){
  const legend = document.getElementById('incomeLegend');
  const incomes = summary.incomes;
  legend.innerHTML = incomes.map(inc => `<button type="button" class="legend-item${state.activeIncome===inc?' active':''}${state.activeIncome&&state.activeIncome!==inc?' muted':''}" data-income="${esc(inc)}"><span class="swatch" style="--swatch:${incomeColours[inc]||'#DFE0E2'}"></span>${esc(inc)}</button>`).join('');
  legend.querySelectorAll('button[data-income]').forEach(btn => btn.addEventListener('click', () => { const inc = btn.dataset.income; state.activeIncome = state.activeIncome === inc ? null : inc; render(); }));
}
function showTooltip(event, d){
  tooltip.hidden = false;
  const xTitle = state.metric === 'migration' ? 'Migrants abroad, 2021' : 'Avg destination GNI, 2021';
  const xVal = state.metric === 'migration' ? fmtMigrants(d.migrants2021) : fmtMoney(d.avgGni2021);
  const yTitle = state.metric === 'migration' ? 'Growth, 2021–24' : 'Change, 2021–24';
  const yVal = state.metric === 'migration' ? fmtPct(d.migrantChangePct) : fmtPct(d.changePct);
  const endTitle = state.metric === 'migration' ? 'Migrants abroad, 2024' : 'Avg destination GNI, 2024';
  const endVal = state.metric === 'migration' ? fmtMigrants(d.migrants2024) : fmtMoney(d.avgGni2024);
  const bubbleRow = state.metric === 'migration' ? `<span>Absolute change</span><b>${fmtMigrants(Math.abs(d.migrantChange))}</b>` : '';
  tooltip.innerHTML = `<strong>${esc(d.name)}</strong><br><span style="color:var(--cgd-dark-gray)">${esc(d.region)} · ${esc(d.income)}</span><div class="tip-grid"><span>${xTitle}</span><b>${xVal}</b><span>${yTitle}</span><b>${yVal}</b><span>${endTitle}</span><b>${endVal}</b>${bubbleRow}</div>`;
  const pad = 12; const rect = tooltip.getBoundingClientRect(); let left = event.clientX + 14; let top = event.clientY + 14;
  if(left + rect.width > window.innerWidth - pad) left = event.clientX - rect.width - 14;
  if(top + rect.height > window.innerHeight - pad) top = event.clientY - rect.height - 14;
  tooltip.style.left = Math.max(pad, left) + 'px'; tooltip.style.top = Math.max(pad, top) + 'px'; tooltip.style.opacity = 1;
}
function hideTooltip(){ tooltip.style.opacity=0; tooltip.hidden=true; }
function renderScatter(){
  const rows = filteredCountries().filter(d => Number.isFinite(xMetric(d)) && Number.isFinite(yMetric(d)) && xMetric(d) > 0);
  const width = svg.clientWidth || 900; const height = svg.clientHeight || 430; const mobile = width < 520;
  const margin = { top: 26, right: mobile ? 13 : 20, bottom: mobile ? 58 : 58, left: mobile ? 62 : 78 };
  const plot = { left: margin.left, top: margin.top, width: width - margin.left - margin.right, height: height - margin.top - margin.bottom };
  const xDom = xDomain(); const yDom = yDomain(rows); const fmtX = valueFormatterX();
  svg.setAttribute('viewBox', `0 0 ${width} ${height}`); svg.innerHTML = '';

  const yZero = yScaleLinear(0, plot, yDom);
  const yTopHalf = yScaleLinear(Math.max(0, yDom[1]), plot, yDom);
  const yBotHalf = yScaleLinear(Math.min(0, yDom[0]), plot, yDom);
  if(yDom[1] > 0){ svg.appendChild(create('rect', {x:plot.left, y:plot.top, width:plot.width, height:Math.max(0, yZero-plot.top), class:'band-positive'})); }
  if(yDom[0] < 0){ svg.appendChild(create('rect', {x:plot.left, y:yZero, width:plot.width, height:Math.max(0, plot.top+plot.height-yZero), class:'band-negative'})); }

  const xTicks = logTicks(xDom); const yTicks = state.metric === 'migration' ? linearTicks(yDom, mobile ? 7 : 8).filter(t => t <= yDom[1] + 1e-9 && t >= yDom[0] - 1e-9) : linearTicks(yDom, mobile ? 5 : 6);
  xTicks.forEach(t => { const x = xScale(t, plot, xDom); svg.appendChild(create('line', {x1:x, x2:x, y1:plot.top, y2:plot.top+plot.height, class:'grid-line'})); });
  yTicks.forEach(t => { const y = yScaleLinear(t, plot, yDom); svg.appendChild(create('line', {x1:plot.left, x2:plot.left+plot.width, y1:y, y2:y, class:'grid-line'})); });

  svg.appendChild(create('line', {x1:plot.left, x2:plot.left+plot.width, y1:yZero, y2:yZero, class:'zero-line'}));
  svg.appendChild(create('text', {x:plot.left+plot.width-4, y:yZero-6, class:'zero-label', 'text-anchor':'end'}, 'No change'));

  const xAxis = create('g', {class:'axis'}); const yAxis = create('g', {class:'axis'}); svg.appendChild(xAxis); svg.appendChild(yAxis);
  svg.appendChild(create('line', {x1:plot.left, x2:plot.left+plot.width, y1:plot.top+plot.height, y2:plot.top+plot.height, class:'axis'}));
  svg.appendChild(create('line', {x1:plot.left, x2:plot.left, y1:plot.top, y2:plot.top+plot.height, class:'axis'}));
  xTicks.forEach(t => { const x = xScale(t, plot, xDom); xAxis.appendChild(create('line', {x1:x,x2:x,y1:plot.top+plot.height,y2:plot.top+plot.height+4})); xAxis.appendChild(create('text', {x:x, y:plot.top+plot.height+18, 'text-anchor':'middle'}, fmtX(t))); });
  yTicks.forEach(t => { const y = yScaleLinear(t, plot, yDom); yAxis.appendChild(create('line', {x1:plot.left-4,x2:plot.left,y1:y,y2:y})); yAxis.appendChild(create('text', {x:plot.left-8, y:y+4, 'text-anchor':'end'}, fmtPctAxis(t))); });

  const xLabel = state.metric === 'migration' ? 'Migrants abroad, 2021' : 'Weighted average destination GNI per capita, 2021';
  const yLabel = state.metric === 'migration' ? 'Growth in migrants abroad, 2021–24' : 'Change in weighted average destination GNI per capita, 2021–24';
  svg.appendChild(create('text', {x:plot.left + plot.width/2, y:height-11, class:'axis-title', 'text-anchor':'middle'}, xLabel));
  svg.appendChild(create('text', {x:15, y:plot.top + plot.height/2, class:'axis-title', 'text-anchor':'middle', transform:`rotate(-90 15 ${plot.top + plot.height/2})`}, yLabel));

  const selected = getSelectedCountry();
  const points = rows.slice().sort((a,b)=>b.migrants2024-a.migrants2024);
  const pointLayer = create('g', {class:'point-layer'}); svg.appendChild(pointLayer);
  points.forEach(d => {
    const selectedThis = state.country === d.id; const mutedBySelection = state.country !== 'ALL' && !selectedThis; const mutedByIncome = state.activeIncome && d.income !== state.activeIncome;
    const x = xScale(xMetric(d), plot, xDom), y = yScaleLinear(yMetric(d), plot, yDom); const r = bubbleRadius(d, width);
    const labelMetric = state.metric === 'migration' ? `migrants abroad ${fmtMigrants(d.migrants2024)} in 2024` : `average destination GNI ${fmtMoney(d.avgGni2024)} in 2024`;
    const isLowIncome = d.income === 'Low income';
    const className = `point${isLowIncome?' low-income':''}${selectedThis?' selected':''}${mutedBySelection||mutedByIncome?' context-muted':''}`;
    const c = create('circle', { cx:x, cy:y, r:r, fill: incomeColours[d.income] || '#DFE0E2', class:className, tabindex:'0', role:'button', 'aria-label':`${d.name}. ${labelMetric}. Click for details.` });
    c.addEventListener('mouseenter', e => showTooltip(e, d)); c.addEventListener('mousemove', e => showTooltip(e, d)); c.addEventListener('mouseleave', hideTooltip);
    c.addEventListener('click', e => { e.stopPropagation(); state.country=d.id; updateCountryInput(); render(); openCountryPopup(d); });
    c.addEventListener('keydown', e => { if(e.key==='Enter' || e.key===' '){ e.preventDefault(); state.country=d.id; updateCountryInput(); render(); openCountryPopup(d); } });
    pointLayer.appendChild(c);
  });
  if(selected){ const x = xScale(xMetric(selected), plot, xDom), y = yScaleLinear(yMetric(selected), plot, yDom); svg.appendChild(create('text', {x:x+10, y:y-10, class:'small-text', 'font-weight':'800'}, selected.name)); }
  const regionLabel = state.region === 'ALL' ? '' : ` · ${state.region}`;
  const panelTitle = document.getElementById('scatterTitle');
  panelTitle.textContent = state.metric === 'migration' ? `Migrants abroad: 2021 baseline and growth to 2024${regionLabel}` : `Destination-country GNI: 2021 baseline and change to 2024${regionLabel}`;
}
function render(){ validateCountry(); renderMetricToggle(); renderLegend(); renderScatter(); renderCountryMenu(); updateCountryInput(); }
function openCountryPopup(d){
  hideTooltip();
  document.getElementById('popupTitle').textContent = d.name;
  document.getElementById('popupSub').textContent = `${d.region} · ${d.income} origin country`;
  const cards = [
    {label:'Destination GNI', value:`${fmtMoney(d.avgGni2021)} → ${fmtMoney(d.avgGni2024)}`, note:`${fmtPct(d.changePct)} change`},
    {label:'Migrants abroad', value:`${fmtMigrants(d.migrants2021)} → ${fmtMigrants(d.migrants2024)}`, note:`${fmtMigrantsSigned(d.migrantChange)} (${fmtPct(d.migrantChangePct)})`}
  ];
  document.getElementById('popupMetrics').innerHTML = cards.map(c=>`<div class="metric-card"><div class="metric-label">${esc(c.label)}</div><div class="metric-value">${esc(c.value)}</div><div class="metric-note">${esc(c.note)}</div></div>`).join('');
  const rows = (destinations[d.id] || []).slice(0, 8);
  document.getElementById('destList').innerHTML = rows.length ? rows.map(r => {
    const changeClass = r.stockChange > 0 ? 'change-pos' : (r.stockChange < 0 ? 'change-neg' : '');
    const pctText = r.stockChangePct == null ? '' : ` (${fmtPct(r.stockChangePct)})`;
    const shareText = `${fmtShare(r.share2021)} → ${fmtShare(r.share2024)}`;
    const stockText = `${fmtMigrants(r.stock2021)} → ${fmtMigrants(r.stock2024)}`;
    return `<div class="dest-row"><div><div class="dest-name">${esc(r.name)}</div><div class="dest-meta">${esc(r.region)} · ${esc(r.income)}</div></div><div class="dest-value"><div class="dest-mini"><span class="lab">2021 stock</span><span class="val">${fmtMigrants(r.stock2021)}</span><span class="lab">2024 stock</span><span class="val">${fmtMigrants(r.stock2024)}</span><span class="lab">Change</span><span class="val ${changeClass}">${fmtMigrantsSigned(r.stockChange)}${pctText}</span><span class="lab">Share of total</span><span class="val">${shareText}</span></div></div></div>`;
  }).join('') : '<div class="select-empty">No destination data available.</div>';
  popup.classList.add('open');
}
function closePopup(){ popup.classList.remove('open'); }
function resetCountrySelection(){ if(state.country !== 'ALL'){ state.country='ALL'; closePopup(); updateCountryInput(); render(); } }
function debounce(fn, ms){ let t; return (...args)=>{ clearTimeout(t); t=setTimeout(()=>fn(...args), ms); }; }
function init(){
  renderRegionSelect();
  metricToggle.querySelectorAll('button[data-metric]').forEach(btn => btn.addEventListener('click', () => { state.metric = btn.dataset.metric; render(); }));
  regionSelect.addEventListener('change', () => { state.region = regionSelect.value; validateCountry(); render(); });
  countryInput.addEventListener('focus', () => { countrySearch=''; openCountryMenu(); });
  countryInput.addEventListener('click', () => { countrySearch=''; openCountryMenu(); });
  countryInput.addEventListener('input', () => { countrySearch = countryInput.value; renderCountryMenu(); });
  document.addEventListener('click', e => { if(!countrySelect.contains(e.target)) closeCountryMenu(); });
  popupClose.addEventListener('click', closePopup); popup.addEventListener('click', e => { if(e.target === popup) closePopup(); });
  svg.addEventListener('click', e => { if(e.target.closest && e.target.closest('.point')) return; resetCountrySelection(); });
  document.addEventListener('keydown', e => { if(e.key==='Escape' && popup.classList.contains('open')) closePopup(); });
  window.addEventListener('resize', debounce(render, 120));
  const wrapper = document.getElementById('vizRoot'); const fullscreenBtn = document.getElementById('fullscreenBtn');
  function syncFullscreenButton(){ const isFullscreen = document.fullscreenElement === wrapper; fullscreenBtn.setAttribute('aria-label', isFullscreen ? 'Exit fullscreen' : 'View fullscreen'); fullscreenBtn.setAttribute('title', isFullscreen ? 'Exit fullscreen' : 'View fullscreen'); setTimeout(render, 80); }
  fullscreenBtn.addEventListener('click', () => { if(document.fullscreenElement === wrapper) document.exitFullscreen?.(); else wrapper.requestFullscreen?.(); });
  document.addEventListener('fullscreenchange', syncFullscreenButton); syncFullscreenButton(); render();
}
init();
</script>
</body>
