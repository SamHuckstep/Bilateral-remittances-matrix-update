<script>
const data = JSON.parse(document.getElementById('vizData').textContent);
const countries = data.countries;
const destinations = data.destinations;
const summary = data.summary;
const state = { metric:'gni', region:'ALL', country:'ALL', activeIncome:null };
const incomeColours = {
  'Low income':'#FEE8BF',
  'Lower middle income':'#FFB52C',
  'Upper middle income':'#2D99B5',
  'High income':'#0B4C5B',
  'No data':'#DFE0E2'
};
const svg = document.getElementById('scatterSvg');
