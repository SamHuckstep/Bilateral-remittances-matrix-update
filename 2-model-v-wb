  function directionOf(d) {
    const model = valueOf(d, 'model'), wb = valueOf(d, 'wb');
    if (model === 0 && wb === 0) return 'similar';
    if (wb === 0 && model > 0) return 'modelHigher';
    if (model === 0 && wb > 0) return 'wbHigher';
    const pct = (model - wb) / wb;
    if (Math.abs(pct) <= 0.10) return 'similar';
    return pct > 0 ? 'modelHigher' : 'wbHigher';
  }
  function directionLabel(d) {
    const dir = directionOf(d);
    if (dir === 'modelHigher') return 'Model higher';
    if (dir === 'wbHigher') return 'World Bank higher';
    return 'Broadly similar';
  }
  function directionColor(d) {
    const dir = directionOf(d);
    if (dir === 'modelHigher') return COLORS.teal;
    if (dir === 'wbHigher') return COLORS.gold;
    return COLORS.tealGray;
  }
  function formatUsd(value) {
    if (value == null || Number.isNaN(value)) return 'N/A';
    const abs = Math.abs(value);
    const sign = value < 0 ? '-' : '';
    if (abs >= 1e12) return `${sign}${(abs / 1e12).toFixed(abs >= 10e12 ? 0 : 1)}tn`;
    if (abs >= 1e9) return `${sign}${(abs / 1e9).toFixed(abs >= 10e9 ? 0 : 1)}bn`;
    if (abs >= 1e6) return `${sign}${(abs / 1e6).toFixed(abs >= 10e6 ? 0 : 1)}m`;
    if (abs >= 1e3) return `${sign}${Math.round(abs).toLocaleString()}`;
    return `${sign}${Math.round(abs).toLocaleString()}`;
  }
  function formatUsdWithDollar(value) {
    const formatted = formatUsd(value);
    if (formatted === 'N/A') return formatted;
    return (formatted.startsWith('-') ? '-$' + formatted.slice(1) : '$' + formatted);
  }
  function formatCount(value) { return Math.round(value).toLocaleString(); }
  function formatRatio(r) { return r == null || !Number.isFinite(r) ? 'N/A' : `${r.toFixed(r >= 10 ? 1 : 2)}×`; }
  function formatPctGap(pct) {
    if (pct == null || !Number.isFinite(pct)) return 'N/A';
    const abs = Math.abs(pct);
    const digits = abs >= 10 ? 0 : 1;
    return `${pct > 0 ? '+' : pct < 0 ? '-' : ''}${abs.toFixed(digits)}%`;
  }
  function gapPhrase(gap, base) {
    if (Math.abs(gap) < 1) return 'no gap';
    if (base > 0) {
      const pct = Math.abs(gap / base * 100);
      const digits = pct >= 10 ? 0 : 1;
      return gap > 0 ? `model higher by ${pct.toFixed(digits)}%` : `model lower by ${pct.toFixed(digits)}%`;
    }
    return gap > 0 ? 'model higher; WB reports zero' : 'World Bank higher; model reports zero';
  }
  function escapeHtml(s) { return String(s).replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch])); }

  class SearchableSelect {
    constructor(root, options, value, onChange, placeholder) {
      this.root = root;
      this.options = options;
      this.value = value;
      this.onChange = onChange;
      this.placeholder = placeholder || 'Search';
      this.renderShell();
      this.updateOptions(options, value);
    }
    renderShell() {
      this.root.innerHTML = `<div class="combo"><button type="button" class="combo__button" aria-haspopup="listbox" aria-expanded="false"></button><div class="combo__menu" hidden><input class="combo__search" type="text" autocomplete="off"><div class="combo__list" role="listbox"></div></div></div>`;
      this.combo = this.root.querySelector('.combo');
      this.button = this.root.querySelector('.combo__button');
      this.menu = this.root.querySelector('.combo__menu');
      this.search = this.root.querySelector('.combo__search');
      this.list = this.root.querySelector('.combo__list');
      this.search.placeholder = this.placeholder;
      this.button.addEventListener('click', () => this.toggle());
      this.search.addEventListener('input', () => this.renderList());
      this.search.addEventListener('keydown', e => { if (e.key === 'Escape') this.close(); });
      document.addEventListener('click', e => { if (!this.combo.contains(e.target)) this.close(); });
    }
    updateOptions(options, value) {
      this.options = options.slice();
      this.value = value;
      const selected = this.options.find(o => o.value === this.value) || this.options[0];
      if (selected) this.value = selected.value;
      this.button.textContent = selected ? selected.label : '';
      this.renderList();
    }
    toggle() { this.menu.hidden ? this.open() : this.close(); }
    open() {
      this.menu.hidden = false;
      this.button.setAttribute('aria-expanded', 'true');
      this.search.value = '';
      this.renderList();
      window.requestAnimationFrame(() => this.search.focus());
    }
    close() {
      this.menu.hidden = true;
      this.button.setAttribute('aria-expanded', 'false');
    }
    renderList() {
      const q = this.search.value.trim().toLowerCase();
      const filtered = this.options.filter(o => o.label.toLowerCase().includes(q));
      if (!filtered.length) { this.list.innerHTML = `<div class="combo__empty">No matches</div>`; return; }
      this.list.innerHTML = filtered.map(o => `<button type="button" class="combo__option" role="option" data-value="${escapeHtml(o.value)}" aria-selected="${o.value === this.value ? 'true' : 'false'}">${escapeHtml(o.label)}</button>`).join('');
      this.list.querySelectorAll('.combo__option').forEach(btn => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-value');
          const opt = this.options.find(o => o.value === val);
          if (!opt) return;
          this.value = opt.value;
          this.button.textContent = opt.label;
          this.close();
          this.onChange(opt.value);
        });
      });
    }
  }

  const incomeSelect = new SearchableSelect(document.getElementById('incomeSelect'), incomeOptions, state.incomeGroup, val => {
    state.incomeGroup = val;
    const valid = countryOptions().some(o => o.value === state.country);
    if (!valid) state.country = 'ALL';
    countrySelect.updateOptions(countryOptions(), state.country);
    updateAllViews();
  }, 'Search income group');

  function countriesForIncome() {
    return rawData.filter(d => state.incomeGroup === 'ALL' || d.income === state.incomeGroup)
      .sort((a,b) => a.country.localeCompare(b.country));
  }
  function countryOptions() {
    return [{ value: 'ALL', label: 'All countries' }].concat(countriesForIncome().map(d => ({ value: d.code, label: d.country })));
  }
  const countrySelect = new SearchableSelect(document.getElementById('countrySelect'), countryOptions(), state.country, val => {
    state.country = val;
    updateAllViews();
  }, 'Search country');

  document.getElementById('year2021').addEventListener('click', () => setYear('2021'));
  document.getElementById('year2024').addEventListener('click', () => setYear('2024'));
  function setYear(year) {
    state.year = year;
    document.getElementById('year2021').setAttribute('aria-pressed', year === '2021');
    document.getElementById('year2024').setAttribute('aria-pressed', year === '2024');
    updateAllViews();
  }

  function contextData() { return countriesForIncome(); }
  function summaryData() {
    const context = contextData();
    if (state.country === 'ALL') return context;
    return context.filter(d => d.code === state.country);
  }
  function selectedCountry() { return rawData.find(d => d.code === state.country) || null; }

  function updateCards() {
    const data = summaryData();
    const totalModel = data.reduce((s,d) => s + valueOf(d, 'model'), 0);
    const totalWb = data.reduce((s,d) => s + valueOf(d, 'wb'), 0);
    const gap = totalModel - totalWb;
    const country = selectedCountry();
    const gapQualifier = gapPhrase(gap, totalWb);
    const countFig = state.country === 'ALL' ? formatCount(data.length) : country.country;
    const countQualifier = state.country === 'ALL' ? 'countries compared' : 'selected country';
    const cards = [
      { label: 'Coverage', figure: countFig, qualifier: countQualifier },
      { label: 'Modelled outflows', figure: formatUsdWithDollar(totalModel), qualifier: 'remittances sent' },
      { label: 'World Bank outflows', figure: formatUsdWithDollar(totalWb), qualifier: 'remittances sent' },
      { label: 'Model–WB gap', figure: formatUsdWithDollar(gap), qualifier: gapQualifier }
    ];
    cardsEl.innerHTML = cards.map(c => `<div class="remit-card"><div class="remit-card__label">${escapeHtml(c.label)}</div><div class="remit-card__line"><span class="remit-card__figure">${escapeHtml(c.figure)}</span><span class="remit-card__qualifier">${escapeHtml(c.qualifier)}</span></div></div>`).join('');
  }

  function updateTitleAndLegend() {
    const incomeLabel = incomeOptions.find(o => o.value === state.incomeGroup)?.label || state.incomeGroup;
    const country = selectedCountry();
    if (state.country === 'ALL') {
      chartTitle.textContent = 'Remittances sent: model versus World Bank';
      chartCaption.textContent = '';
    } else {
      chartTitle.textContent = `${country.country} in context: model versus World Bank`;
      chartCaption.textContent = '';
    }
    legendEl.innerHTML = [
      `<span class="remit-viz__legend-item"><span class="remit-viz__swatch" style="background:${COLORS.teal}"></span>Model higher</span>`,
      `<span class="remit-viz__legend-item"><span class="remit-viz__swatch" style="background:${COLORS.tealGray}"></span>Broadly similar</span>`,
      `<span class="remit-viz__legend-item"><span class="remit-viz__swatch" style="background:${COLORS.gold}"></span>World Bank higher</span>`,
      state.country !== 'ALL' ? `<span class="remit-viz__legend-item"><span class="remit-viz__swatch" style="background:${COLORS.red}"></span>Selected country</span>` : ''
    ].join('');
  }

  function maxNice(v) {
    const ticks = [1e6, 1e7, 1e8, 1e9, 1e10, 1e11, 1e12, 1e13];
    return ticks.find(t => t >= v) || 1e13;
  }
  function axisTicks(maxVal, width) {
    const base = [0, 1e6, 1e7, 1e8, 1e9, 1e10, 1e11, 1e12, 1e13].filter(t => t <= maxVal);
    if (!base.includes(maxVal)) base.push(maxVal);
    const small = width < 600;
    if (!small || base.length <= 6) return base;
    return base.filter((_, i) => i === 0 || i === base.length - 1 || i % 2 === 0);
  }
  const SCALE_CONSTANT = 1e6;
  function scaleLog(v, domainMax, rangeMin, rangeMax) {
    const safe = Math.max(0, v);
    const t = Math.log1p(safe / SCALE_CONSTANT) / Math.log1p(domainMax / SCALE_CONSTANT);
    return rangeMin + t * (rangeMax - rangeMin);
  }
  function makeEl(tag, attrs, text) {
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    Object.entries(attrs || {}).forEach(([k,v]) => el.setAttribute(k, v));
    if (text != null) el.textContent = text;
    return el;
  }

  function addPillLabel(parent, attrs, text, rectClass) {
    const group = makeEl('g', { class: 'label-group' });
    const label = makeEl('text', attrs, text);
    group.appendChild(label);
    parent.appendChild(group);
    try {
      const box = label.getBBox();
      const padX = 4.5;
      const padY = 2.5;
      const rect = makeEl('rect', {
        x: box.x - padX,
        y: box.y - padY,
        width: box.width + padX * 2,
        height: box.height + padY * 2,
        rx: 4,
        ry: 4,
        class: rectClass
      });
      group.insertBefore(rect, label);
    } catch (e) {
      // If getBBox is unavailable in a host environment, the text label still renders safely.
    }
    return group;
  }

  function estimatedLabelBox(text, x, y, anchor) {
    const width = Math.max(44, text.length * 6.2 + 10);
    const height = 16;
    let left = x;
    if (anchor === 'end') left = x - width;
    if (anchor === 'middle') left = x - width / 2;
    return { x: left, y: y - 12, width, height };
  }
  function boxesOverlap(a, b, pad = 4) {
    return a.x < b.x + b.width + pad && a.x + a.width + pad > b.x && a.y < b.y + b.height + pad && a.y + a.height + pad > b.y;
  }
  function clampLabel(text, candidate, innerW, innerH) {
    const box = estimatedLabelBox(text, candidate.x, candidate.y, candidate.anchor);
    let x = candidate.x;
    let y = candidate.y;
    if (box.x < 3) x += 3 - box.x;
    if (box.x + box.width > innerW - 3) x -= box.x + box.width - (innerW - 3);
    if (box.y < 3) y += 3 - box.y;
    if (box.y + box.height > innerH - 3) y -= box.y + box.height - (innerH - 3);
    return { x, y, anchor: candidate.anchor, box: estimatedLabelBox(text, x, y, candidate.anchor) };
  }
  function choosePointLabelPosition(text, px, py, preferAbove, innerW, innerH, occupied) {
    const preferRight = px < innerW - 150;
    const primaryAnchor = preferRight ? 'start' : 'end';
    const secondaryAnchor = preferRight ? 'end' : 'start';
    const primaryDx = preferRight ? 10 : -10;
    const secondaryDx = preferRight ? -10 : 10;
    const primaryY = preferAbove ? -10 : 17;
    const secondaryY = preferAbove ? 17 : -10;
    const candidates = [
      { x: px + primaryDx, y: py + primaryY, anchor: primaryAnchor },
      { x: px + primaryDx, y: py + secondaryY, anchor: primaryAnchor },
      { x: px + secondaryDx, y: py + primaryY, anchor: secondaryAnchor },
      { x: px + secondaryDx, y: py + secondaryY, anchor: secondaryAnchor },
      { x: px + primaryDx, y: py + 30, anchor: primaryAnchor },
      { x: px + primaryDx, y: py - 24, anchor: primaryAnchor }
    ].map(c => clampLabel(text, c, innerW, innerH));
    return candidates.find(c => !occupied.some(box => boxesOverlap(c.box, box))) || candidates[0];
  }

  function renderChart() {
    const data = contextData();
    const selected = selectedCountry();
    const width = Math.max(320, Math.floor(chartWrap.clientWidth));
    const height = width < 560 ? 370 : 430;
    const margin = { top: 12, right: 18, bottom: width < 560 ? 56 : 62, left: width < 560 ? 50 : 68 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;
    const maxRaw = Math.max(1, ...data.flatMap(d => [valueOf(d, 'model'), valueOf(d, 'wb')]));
    const domainMax = maxNice(maxRaw * 1.04);
    const ticks = axisTicks(domainMax, width);
    const svg = makeEl('svg', { viewBox: `0 0 ${width} ${height}`, role: 'img', 'aria-label': 'Scatter chart comparing modelled remittances sent with World Bank remittances sent' });
    const plot = makeEl('g', { transform: `translate(${margin.left},${margin.top})` });
    svg.appendChild(plot);

    const x = v => scaleLog(v, domainMax, 0, innerW);
    const y = v => innerH - scaleLog(v, domainMax, 0, innerH);

    let lastXLabel = -Infinity;
    let lastYLabel = Infinity;
    ticks.forEach(t => {
      const px = x(t), py = y(t);
      plot.appendChild(makeEl('line', { x1: px, x2: px, y1: 0, y2: innerH, class: 'grid-line' }));
      plot.appendChild(makeEl('line', { x1: 0, x2: innerW, y1: py, y2: py, class: 'grid-line' }));
      const label = t === 0 ? '0' : '$' + formatUsd(t);
      if (t === 0 || px - lastXLabel > (width < 560 ? 42 : 48) || t === domainMax) {
        const xt = makeEl('text', { x: px, y: innerH + 20, 'text-anchor': 'middle', class: 'axis tick' }, label);
        plot.appendChild(xt);
        lastXLabel = px;
      }
      if (t === 0 || lastYLabel - py > 24 || t === domainMax) {
        const yt = makeEl('text', { x: -8, y: py + 4, 'text-anchor': 'end', class: 'axis tick' }, label);
        plot.appendChild(yt);
        lastYLabel = py;
      }
    });

    plot.appendChild(makeEl('line', { x1: 0, x2: innerW, y1: innerH, y2: innerH, class: 'axis-line' }));
    plot.appendChild(makeEl('line', { x1: 0, x2: 0, y1: 0, y2: innerH, class: 'axis-line' }));
    plot.appendChild(makeEl('line', { x1: 0, y1: innerH, x2: innerW, y2: 0, class: 'equal-line' }));
    const labelBoxes = [];
    const equalLabel = clampLabel('Equal values', { x: innerW - 8, y: 27, anchor: 'end' }, innerW, innerH);
    addPillLabel(plot, { x: equalLabel.x, y: equalLabel.y, 'text-anchor': equalLabel.anchor, class: 'equal-label' }, 'Equal values', 'equal-label-bg');
    labelBoxes.push(equalLabel.box);

    const xTitle = makeEl('text', { x: margin.left + innerW / 2, y: height - 21, 'text-anchor': 'middle', class: 'axis-title' }, 'World Bank remittances sent (current US$)');
    svg.appendChild(xTitle);
    const yTitle = makeEl('text', { x: 16, y: margin.top + innerH / 2, transform: `rotate(-90, 16, ${margin.top + innerH / 2})`, 'text-anchor': 'middle', class: 'axis-title' }, 'Modelled remittances sent (current US$)');
    svg.appendChild(yTitle);

    const pointsG = makeEl('g', {});
    plot.appendChild(pointsG);
    data.forEach(d => {
      const isSelected = selected && d.code === selected.code;
      const isMuted = selected && !isSelected;
      const c = makeEl('circle', {
        cx: x(valueOf(d, 'wb')),
        cy: y(valueOf(d, 'model')),
        r: isSelected ? 7.2 : (width < 560 ? 4.2 : 5.1),
        fill: isSelected ? COLORS.red : directionColor(d),
        stroke: isSelected ? COLORS.tealBlack : 'white',
        'stroke-width': isSelected ? 1.6 : 0.75,
        opacity: isMuted ? 0.22 : 0.78,
        class: 'point',
        tabindex: 0,
        'aria-label': `${d.country}, modelled ${formatUsdWithDollar(valueOf(d, 'model'))}, World Bank ${formatUsdWithDollar(valueOf(d, 'wb'))}`
      });
      c.addEventListener('mousemove', ev => showTooltip(ev, d));
      c.addEventListener('mouseenter', ev => showTooltip(ev, d));
      c.addEventListener('mouseleave', hideTooltip);
      c.addEventListener('focus', ev => showTooltip(ev, d));
      c.addEventListener('blur', hideTooltip);
      c.addEventListener('click', ev => {
        ev.stopPropagation();
        hideTooltip();
        state.country = d.code;
        countrySelect.updateOptions(countryOptions(), state.country);
        updateAllViews();
      });
      pointsG.appendChild(c);
    });

    const labels = [];
    if (selected) { labels.push(selected); }
    else {
      data.slice().sort((a,b) => Math.abs(diffOf(b)) - Math.abs(diffOf(a))).slice(0, width < 560 ? 3 : 5).forEach(d => labels.push(d));
    }
    labels.forEach(d => {
      const px = x(valueOf(d, 'wb')), py = y(valueOf(d, 'model'));
      const aboveParity = valueOf(d, 'model') >= valueOf(d, 'wb');
      const label = choosePointLabelPosition(d.country, px, py, aboveParity, innerW, innerH, labelBoxes);
      addPillLabel(plot, { x: label.x, y: label.y, 'text-anchor': label.anchor, class: 'point-label' }, d.country, 'point-label-bg');
      labelBoxes.push(label.box);
    });

    chartWrap.innerHTML = '';
    chartWrap.appendChild(svg);
  }

  function showTooltip(ev, d) {
    const model = valueOf(d, 'model'), wb = valueOf(d, 'wb'), gap = model - wb, ratio = wb > 0 ? model / wb : null;
    const pctGap = wb > 0 ? ((gap / wb) * 100) : null;
    tooltip.innerHTML = `
      <div class="remit-tooltip__title">${escapeHtml(d.country)}</div>
      <div>${escapeHtml(d.income)} · ${state.year} · ${escapeHtml(directionLabel(d))}</div>
      <div class="remit-tooltip__row"><span>Modelled</span><span>${formatUsdWithDollar(model)}</span></div>
      <div class="remit-tooltip__row"><span>World Bank</span><span>${formatUsdWithDollar(wb)}</span></div>
      <div class="remit-tooltip__row"><span>Gap</span><span>${formatUsdWithDollar(gap)}</span></div>
      <div class="remit-tooltip__row"><span>Model / WB</span><span>${formatPctGap(pctGap)}</span></div>
    `;
    tooltip.hidden = false;
    const coords = pointerCoords(ev);
    if (coords) positionTooltip(coords.x, coords.y);
  }
  function pointerCoords(ev) {
    const touch = ev.touches?.[0] || ev.changedTouches?.[0];
    if (touch && Number.isFinite(touch.clientX) && Number.isFinite(touch.clientY)) {
      return { x: touch.clientX, y: touch.clientY };
    }
    if (Number.isFinite(ev.clientX) && Number.isFinite(ev.clientY)) {
      return { x: ev.clientX, y: ev.clientY };
    }
    const target = ev.currentTarget || ev.target;
    if (target && typeof target.getBoundingClientRect === 'function') {
      const rect = target.getBoundingClientRect();
      return { x: rect.left + rect.width / 2, y: rect.top + rect.height / 2 };
    }
    return null;
  }
  function positionTooltip(clientX, clientY) {
    const pad = 12;
    const offset = 16;
    const box = tooltip.getBoundingClientRect();
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    let left;
    if (clientX + offset + box.width <= vw - pad) {
      left = clientX + offset;
    } else if (clientX - offset - box.width >= pad) {
      left = clientX - offset - box.width;
    } else {
      left = Math.max(pad, Math.min(vw - pad - box.width, clientX + offset));
    }
    let top;
    if (clientY + offset + box.height <= vh - pad) {
      top = clientY + offset;
    } else if (clientY - offset - box.height >= pad) {
      top = clientY - offset - box.height;
    } else {
      top = Math.max(pad, Math.min(vh - pad - box.height, clientY + offset));
    }
    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;
  }
  function hideTooltip() { tooltip.hidden = true; }

  function updateAllViews() {
    updateCards();
    updateTitleAndLegend();
    renderChart();
  }

  const fullscreenBtn = document.getElementById('fullscreenBtn');
  function syncFullscreenButton() {
    const isFullscreen = document.fullscreenElement === wrapper;
    fullscreenBtn.setAttribute('aria-label', isFullscreen ? 'Exit fullscreen' : 'View fullscreen');
    fullscreenBtn.setAttribute('title', isFullscreen ? 'Exit fullscreen' : 'View fullscreen');
  }
  fullscreenBtn.addEventListener('click', () => {
    if (document.fullscreenElement) document.exitFullscreen?.();
    else wrapper.requestFullscreen?.();
  });
  document.addEventListener('fullscreenchange', () => {
    syncFullscreenButton();
    hideTooltip();
    window.setTimeout(renderChart, 80);
  });
  syncFullscreenButton();
  window.addEventListener('resize', () => { window.clearTimeout(window.__remitResize); window.__remitResize = window.setTimeout(renderChart, 120); });
  chartWrap.addEventListener('click', e => {
    if (e.target.closest && e.target.closest('.point')) return;
    hideTooltip();
    if (state.country !== 'ALL') {
      state.country = 'ALL';
      countrySelect.updateOptions(countryOptions(), state.country);
      updateAllViews();
    }
  });
  wrapper.addEventListener('click', e => { if (e.target === wrapper) hideTooltip(); });

  updateAllViews();
})();
</script>
</body>
</html>
